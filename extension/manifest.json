{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.5.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": ["tabs", "scripting", "alarms", "debugger", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "sw.js" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "__MSG_extName__",
    "default_popup": "chat.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
